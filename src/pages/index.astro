---
import MainLayout from "../layouts/MainLayout.astro";
import Project from "../components/Project.astro";
import Skill from "../components/Skill.astro";

const person = {
    "@context": "https://schema.org",
    "@type": "person",
    "@id": "https://twilight.horse",
    name: "compscitwilight",
    alternateName: ["Skylar", "Rust"],
    url: "https://twilight.horse",
    image: "https://derpicdn.net/img/2025/1/1/3518770/full.png",
    jobTitle: "Software Developer",
    description:
        "Rust (Skylar), also known online as compscitwilight, is a computer science student and full-stack developer building open-source software, web applications, browser extensions, and real-time systems.",
    sameAs: [
        "https://github.com/compscitwilight/",
        "https://x.com/compscitwilight",
        "https://rateyourmusic.com/~compscitwilight/",
        "https://glitchwave.com/user/compscitwilight/",
    ],
    knowsAbout: [
        "TypeScript",
        "Go",
        "Python",
        "Rust",
        "React",
        "Next.js",
        "Astro",
        "Node.js",
        "Linux",
        "PostgreSQL",
        "Redis",
        "Docker",
    ],
};
---

<MainLayout>
    <!-- head -->
    <Fragment slot="head">
        <title>compscitwilight</title>
        <meta
            property="og:image"
            content="https://twilight.horse/3518770.png"
        />
        <link rel="canonical" href="https://twilight.horse/" />
        <script type="application/ld+json" set:html={JSON.stringify(person)} />
    </Fragment>

    <!-- site content  -->
    <div
        class="grid grid-cols-1 md:grid-cols-2 md:h-screen max-h-screen overflow-y-auto md:mt-4 h-full gap-4"
    >
        <!-- bio  -->
        <div
            class="flex flex-col w-full max-w-screen-md mx-auto text-center gap-4 px-4 pt-8 pb-12 md:h-full md:max-h-full md:overflow-y-auto custom-scrollbar md:pb-32"
        >
            <!-- header -->
            <div
                class="flex flex-col sm:flex-row justify-around items-center gap-16 sm:gap-0"
            >
                <a
                    title="art by unitxxvii"
                    href="https://derpibooru.org/3518770"
                    target="_blank"
                >
                    <img class="m-auto w-[256px]" src="/3518770.png" />
                </a>
                <div>
                    <div>
                        <h1 class="text-3xl font-bold">compscitwilight</h1>
                        <p>developer & student</p>
                    </div>
                    <div class="mt-2">
                        <p>
                            Full-stack developer who writes in TypeScript and
                            Go.
                        </p>
                    </div>
                    <div
                        class="flex gap-2 justify-center items-center px-16 py-4"
                    >
                        <a
                            href="https://github.com/compscitwilight"
                            target="_blank"
                        >
                            <img
                                class="w-[32px]"
                                src="/social_images/github.png"
                            />
                        </a>
                        <a href="https://x.com/compscitwilight" target="_blank">
                            <img
                                class="w-[32px]"
                                src="/social_images/twitter.png"
                            />
                        </a>
                        <a
                            href="https://discord.com/users/472530726613549066"
                            target="_blank"
                        >
                            <img
                                class="w-[32px] text-white"
                                src="/social_images/discord.svg"
                            />
                        </a>
                        <a
                            href="https://rateyourmusic.com/~compscitwilight"
                            target="_blank"
                        >
                            <img
                                class="w-[32px] text-white"
                                src="/social_images/rym.svg"
                            />
                        </a>
                    </div>
                </div>
            </div>

            {/* about me */}
            <div class="text-left">
                <div>
                    <h2 class="font-bold text-xl">About me</h2>
                    <hr class="twilight-purple my-2" />
                    <p>
                        Hi, I go by <strong>Rust</strong> (or <strong
                            >Skylar</strong
                        >). I am a computer science student and full-stack
                        developer specializing in TypeScript and Go. I'm
                        involved in web development, systems engineering,
                        real-time networking, and browser extensions.
                    </p>
                </div>
            </div>

            {/* skills */}
            <div class="grid gap-2 text-left">
                <div>
                    <h2 class="text-xl font-bold">Programming languages</h2>
                    <div class="flex flex-wrap mt-1 items-center gap-2">
                        <Skill name="typescript" />
                        <Skill name="go" />
                        <Skill name="python" />
                        <Skill name="rust" />
                        <Skill name="lua" />
                        <Skill name="cs" />
                    </div>
                </div>
                <div>
                    <h2 class="text-xl font-bold">Frameworks & Libraries</h2>
                    <div class="flex flex-wrap mt-1 items-center gap-2">
                        <Skill name="node.js" />
                        <Skill name="react" />
                        <Skill name="next.js" />
                        <Skill name="tailwind" />
                        <Skill name="sass" />
                        <Skill name="vite.js" />
                        <Skill name="socket.io" />
                        <Skill name="astro" />
                        <Skill name="express" />
                        <Skill name="vue.js" />
                        <Skill name="fastify" />
                        <Skill name="selenium" />
                        <Skill name="prisma.js" />
                        <Skill name="discord.js" />
                        <Skill name="sequelize" />
                        <Skill name="roblox-studio" />
                        <Skill name="electron" />
                    </div>
                </div>
                <div>
                    <h2 class="text-xl font-bold">
                        Databases & Infrastructure
                    </h2>
                    <div class="flex flex-wrap mt-1 items-center gap-2">
                        <Skill name="postgres" />
                        <Skill name="redis" />
                        <Skill name="sqlite" />
                        <Skill name="docker" />
                        <Skill name="vercel" />
                        <Skill name="cloudflare" />
                        <Skill name="proxmox" />
                        <Skill name="aws" />
                    </div>
                </div>
                <div>
                    <h2 class="text-xl font-bold">Tools & APIs</h2>
                    <div class="flex flex-wrap mt-1 items-center gap-2">
                        <Skill name="git" />
                        <Skill name="github" />
                        <Skill name="linux" />
                        <Skill name="debian" />
                        <Skill name="arch-linux" />
                        <Skill name="fedora" />
                        <Skill name="bash" />
                        <Skill name="google-cloud" />
                        <Skill name="vscode" />
                        <Skill name="vim" />
                    </div>
                </div>
            </div>
        </div>

        <!-- <SpotifyCurrentTrack /> -->

        {/* projects */}
        <div
            class="grid grid-cols-1 w-full max-w-screen-md mx-auto text-left gap-8 px-4 content-start md:mt-4 md:overflow-y-auto custom-scrollbar"
        >
            <div>
                <h2 class="font-bold text-2xl">Featured Project</h2>
                <hr class="twilight-purple my-2" />
                <Project
                    title="TrashNSell.com"
                    imageSrc="/showcase/trashnsell.png"
                    technology={[
                        "typescript",
                        "next.js",
                        "postgres",
                        "google-cloud",
                    ]}
                    externalLink="https://trashnsell.com"
                    status="Stable"
                    date="Jun 2026 - present"
                >
                    <p>
                        Full-stack business operations platform built for a junk
                        removal company, featuring a price estimation engine,
                        job management system, applicant tracking, and automated
                        invoicing via the Square API. Integrates Google Places
                        and Calendar APIs to streamline scheduling and customer
                        workflows, with Sentry for monitoring. Generated leads
                        and increased revenue while reducing the need for
                        speculative pricing.
                    </p>
                    <p>
                        Built for TrashNSell Junk Removal in Grand Island, NE.
                    </p>
                </Project>
            </div>

            <div>
                <h2 class="text-2xl font-bold">Latest Project</h2>
                <hr class="twilight-purple my-2" />
                <Project
                    title="PonyCCG"
                    imageSrc="/showcase/ponyccg.png"
                    technology={[
                        "typescript",
                        "nuxt.js",
                        "discord.js",
                        "openai",
                        "postgres",
                    ]}
                    externalLink="https://github.com/compscitwilight/PonyCCG"
                    date="Jun 2026 - present"
                    status="Development"
                >
                    <p>
                        Full-stack MLP:CCG engine and ecosystem featuring an
                        event-driven Discord bot, deckbuilding dashboard built
                        in Nuxt.js, and automated card parsing and ruleset
                        generation via an LLM pipeline using the OpenAI API.
                    </p>
                    <p>
                        Uses a shared PostgreSQL database and Drizzle ORM,
                        Discord OAuth for cross-platform authentication, and a
                        real-time SVG viewport generator to render match
                        canvases in a Discord message.
                    </p>
                </Project>
            </div>

            <div>
                <h2 class="text-2xl font-bold">Other Projects</h2>
                <hr class="twilight-purple my-2" />
                <div class="grid gap-2">
                    <Project
                        title="TranslateYourReviews"
                        imageSrc="/showcase/translateyourreviews.png"
                        imageSize="w-[128px]"
                        externalLink="https://github.com/compscitwilight/TranslateYourReviews"
                        technology={["typescript", "express", "redis"]}
                        date="May 2026"
                        status="Stable"
                    >
                        <p>
                            A browser extension built in TypeScript that
                            enhances <a
                                class="text-sky-300 underline"
                                target="_blank"
                                href="https://rateyourmusic.com"
                                >RateYourMusic</a
                            > by adding DeepL-powered translations directly to user
                            reviews. It detects multiple languages, injects a translate
                            button into release pages, and speeds up repeated lookups
                            with a custom caching proxy.
                        </p>
                        <p>
                            Available on the <a
                                class="text-sky-300 underline"
                                href="https://chromewebstore.google.com/detail/translateyourreviews/afidebkjbnljodfoleehhhendihaijlj"
                                target="_blank">Chrome Web Store</a
                            > and the <a
                                class="text-sky-300 underline"
                                href="https://addons.mozilla.org/en-US/firefox/addon/translateyourreviews/"
                                target="_blank">Mozilla Addons Store</a
                            >.
                        </p>
                    </Project>

                    <Project
                        title="pipette"
                        imageSrc="/showcase/pipette.png"
                        externalLink="https://github.com/compscitwilight/pipette"
                        technology={["go"]}
                        date="May 2026"
                        status="Stable"
                    >
                        <p>
                            A command-line utility written in Go that fills
                            block devices by intelligently selecting and copying
                            files to match a target device capacity threshold.
                            Accounts for available space, skips previously
                            transferred files via device UUID caching, and
                            displays progress in the command line during
                            transfers.
                        </p>
                    </Project>

                    <Project
                        title="The Pony Archive Search"
                        imageSrc="/showcase/tpa-search.png"
                        externalLink="https://search.twilight.horse"
                        technology={[
                            "typescript",
                            "react",
                            "express",
                            "postgres",
                        ]}
                        date="Apr 2026"
                        status="Stable"
                    >
                        <p>
                            Open-source search interface for <a
                                target="_blank"
                                href="https://theponyarchive.com"
                                >The Pony Archive</a
                            >

                            with an index of 1.2M+ files. Supports trigram
                            search, uploader linkage, and a public

                            <a
                                class="text-sky-300 underline"
                                target="_blank"
                                href="https://search.twilight.horse/download"
                                >PSQL dump</a
                            >. Express backend deployed on Fly.io with a React
                            frontend deployed on Cloudflare Pages.
                        </p>
                    </Project>

                    <Project
                        title="Herd"
                        imageSrc="/showcase/herd.png"
                        externalLink="https://herd.twilight.horse"
                        technology={["typescript", "vite.js", "socket.io"]}
                        date="Mar 2026"
                        status="Development"
                    >
                        <p>
                            An upcoming real-time multiplayer game where players
                            collect ponies to form herds. Featured dynamic herd
                            formations, server authoritative state, and an
                            in-house asset manager that works natively with <a
                                class="text-sky-300 underline"
                                href="https://pony.town">pony.town</a
                            >

                            sprites.
                        </p>

                        <p>
                            Built with Pixi.js, Vite, Tailwind, Socket.io,
                            Express; deployed with Cloudflare Pages and
                            Cloudflare Tunnels.
                        </p>
                    </Project>

                    <Project
                        title="ponies.fyi"
                        imageSrc="/showcase/ponies.fyi.png"
                        externalLink="https://ponies.fyi"
                        technology={[
                            "typescript",
                            "next.js",
                            "postgres",
                            "cloudflare",
                        ]}
                        date="Feb 2026"
                        status="Stable"
                    >
                        <p>
                            An open-source index of brony fandom OCs with
                            structured metadata, revision history, attribution
                            tracking, and a notability system for historically
                            significant characters. Built using TypeScript,
                            Next.js, Prisma, and Cloudflare R2.
                        </p>
                    </Project>

                    <Project
                        title="twilight.horse"
                        externalLink="https://twilight.horse"
                        technology={["astro", "cloudflare"]}
                        date="Feb 2026"
                        status="Stable"
                    >
                        <p>
                            my personal site that you're on right now! Built
                            using Astro and hosted with Cloudflare Pages. Source
                            code available <a
                                class="text-sky-300 underline"
                                target="_blank"
                                href="https://github.com/compscitwilight/twilight.horse"
                                >here</a
                            >.
                        </p>
                    </Project>

                    <Project
                        title="PonyAggregate"
                        externalLink="https://ponyaggregate.com"
                        technology={[
                            "typescript",
                            "next.js",
                            "postgres",
                            "cloudflare",
                        ]}
                        date="Dec 2025"
                        status="Archived"
                    >
                        <p>
                            Platform for archiving pony fandom content. Built
                            using a stack of TypeScript, Next.js, Prisma,
                            Supabase, and Cloudflare R2, and deployed with
                            Vercel.
                        </p>
                    </Project>

                    <div class="h-48 w-full clear-both"></div>
                </div>
            </div>
        </div>
    </div>
</MainLayout>
